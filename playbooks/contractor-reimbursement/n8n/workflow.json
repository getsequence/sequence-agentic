      "parameters": {
        "resource": "message",
        "operation": "post",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $('Resolve Contractor').first().json.trigger.channelId }}"
        },
        "messageType": "text",
        "text": "=:white_check_mark: Reimbursed ${{ ($('Resolve Contractor').first().json.receipt.amount_cents / 100).toFixed(2) }} to {{ $('Resolve Contractor').first().json.contractor.name }}. Transfer ID(s): {{ ($json.data.transferIds || []).join(', ') || 'pending — poll executions for the final state' }}",
