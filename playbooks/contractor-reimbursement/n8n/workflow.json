              "name": "Idempotency-Key",
              "value": "=dry-{{ $('Resolve Contractor').first().json.trigger.fileId }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ simulation: true, executeAmount: $('Resolve Contractor').first().json.receipt.amount_cents }) }}",
        "options": {}
      },
      "id": "node-017",
      "name": "Dry Run (Simulation)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3880,
        1040
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE",
          "name": "Sequence API"
        }
      }
    },
    {
      "parameters": {
        "amount": 3,
        "unit": "seconds"
      },
      "id": "node-018",
      "name": "Wait for Sim",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        4160,
        1040
      ],
      "webhookId": "wait-sim"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $('Resolve Contractor').first().json.config.sequence.baseUrl }}/rules/{{ $('Resolve Contractor').first().json.contractor.ruleId }}/executions/{{ $('Dry Run (Simulation)').first().json.data.executionId }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "node-019",
      "name": "Poll Sim Execution",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        4440,
        1040
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE",
          "name": "Sequence API"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "id": "cond-sim",
              "leftValue": "={{ $json.data.status === 'EXECUTED' && $json.data.conditionsNotMet === false && $json.data.transfersFailed === 0 }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-020",
      "name": "Dry Run Clean?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        4720,
        1040
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "post",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $('Resolve Contractor').first().json.trigger.channelId }}"
