            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ executeAmount: $('Resolve Contractor').first().json.receipt.amount_cents }) }}",
        "options": {}
      },
