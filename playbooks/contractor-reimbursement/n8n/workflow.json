        }
      },
      "id": "node-016",
      "name": "Reply: Rejected",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.3,
      "position": [
        3880,
        640
      ],
      "credentials": {
        "slackApi": {
          "id": "REPLACE",
          "name": "Slack account"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Resolve Contractor').first().json.config.sequence.baseUrl }}/rules/{{ $('Resolve Contractor').first().json.contractor.ruleId }}/trigger",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
