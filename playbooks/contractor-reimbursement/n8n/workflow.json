{
  "name": "Contractor Expense Reimbursement via Slack",
  "nodes": [
    {
      "parameters": {
        "trigger": [
          "file_shared"
        ],
        "options": {}
      },
      "id": "node-001",
      "name": "Receipt Posted (Slack Trigger)",
      "type": "n8n-nodes-base.slackTrigger",
      "typeVersion": 1,
      "position": [
        240,
        440
      ],
      "credentials": {
        "slackApi": {
          "id": "REPLACE",
          "name": "Slack account"
        }
      },
      "webhookId": "slack-receipt"
    },
    {
      "parameters": {
        "jsCode": "// ============================================================\n// EDIT YOUR CONFIG HERE — single source of truth.\n// Secrets (Sequence / Slack / OpenRouter keys) live in n8n\n// credentials, NOT in this node. All amounts are integer cents.\n// ============================================================\nconst config = {\n  sequence: { baseUrl: \"https://api.getsequence.io/platform/v1\" },\n  slack: { expenseChannelId: \"C0XXXXXXXXX\", approverUserId: \"U0MANAGERXXX\" },\n  llm: { model: \"anthropic/claude-sonnet-4\" },\n  approval: { reminderAfterMinutes: 60, escalateAfterMinutes: 240 },\n  policy: {\n    currency: \"USD\",\n    categories: {\n      meals: { maxAmountCents: 7500 },\n      travel: { maxAmountCents: 100000 },\n      software: { maxAmountCents: 50000 },\n      supplies: { maxAmountCents: 25000 },\n      lodging: { maxAmountCents: 200000 },\n    },\n  },\n  roster: {\n    \"U0CONTRACTOR1\": { name: \"Alex Rivera\", ruleId: \"REPLACE_WITH_RULE_ID\" },\n    \"U0CONTRACTOR2\": { name: \"Sam Chen\", ruleId: \"REPLACE_WITH_RULE_ID\" },\n  },\n};\n\n// Normalize the Slack trigger payload. Field names vary by event type —\n// after the first run, pin the trigger output and adjust these if needed.\nconst ev = $input.first().json;\nconst trigger = {\n  fileId: ev.file_id || (ev.event && ev.event.file_id) || ev.file || null,\n  channelId: ev.channel_id || ev.channel || (ev.event && ev.event.channel) || config.slack.expenseChannelId,\n  userId: ev.user_id || ev.user || (ev.event && ev.event.user) || null,\n  threadTs: ev.event_ts || ev.ts || (ev.event && ev.event.event_ts) || null,\n};\n\nreturn [{ json: { config, trigger } }];"
      },
      "id": "node-002",
      "name": "Load Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        520,
        440
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://slack.com/api/files.info",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "file",
              "value": "={{ $json.trigger.fileId }}"
            }
          ]
        },
        "options": {}
      },
      "id": "node-003",
      "name": "Get File Info",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        800,
        440
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE",
          "name": "Slack Bot Token (xoxb)"
        }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.file.url_private }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file",
              "outputPropertyName": "data"
            }
          }
        }
      },
      "id": "node-004",
      "name": "Download Receipt",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1080,
        440
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE",
          "name": "Slack Bot Token (xoxb)"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst bin = item.binary.data;\nconst dataUrl = `data:${bin.mimeType};base64,${bin.data}`;\nconst model = $('Load Config').first().json.config.llm.model;\nconst requestBody = {\n  model,\n  messages: [\n    { role: 'system', content: 'You are an expense-receipt parser. Respond with ONLY a compact JSON object and no prose.' },\n    { role: \"user\", content: [\n      { type: 'text', text: 'From this receipt image extract these keys: amount_cents (integer, total in cents), currency (ISO 4217 code), vendor (string), category (one of: meals, travel, software, supplies, lodging, other), date (YYYY-MM-DD). Use null for anything unreadable. Respond with ONLY the JSON object.' },\n      { type: \"image_url\", image_url: { url: dataUrl } },\n    ] },\n  ],\n};\nreturn [{ json: { requestBody } }];"
      },
      "id": "node-005",
      "name": "Build Image Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        440
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.requestBody) }}",
        "options": {}
      },
      "id": "node-006",
      "name": "Read Receipt (OpenRouter)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1640,
        440
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE",
          "name": "OpenRouter"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst msg = raw.choices && raw.choices[0] ? raw.choices[0].message : null;\nlet content = msg ? msg.content : '';\ncontent = String(content).trim();\nif (content.indexOf('```') !== -1) {\n  content = content.replace(/```json/gi, '').replace(/```/g, '').trim();\n}\nlet parsed = null;\ntry { parsed = JSON.parse(content); } catch (e) { parsed = null; }\nconst cfg = $('Load Config').first().json;\nreturn [{ json: { receipt: parsed, parseError: parsed ? null : content, config: cfg.config, trigger: cfg.trigger } }];"
      },
      "id": "node-007",
      "name": "Parse Extraction",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1920,
        440
      ]
    },
    {
      "parameters": {
        "jsCode": "const j = $input.first().json;\nconst r = j.receipt || {};\nconst policy = j.config.policy;\nlet valid = true; let reason = null;\nif (!j.receipt || r.amount_cents == null) {\n  valid = false; reason = 'Could not read an amount from the receipt.';\n} else if (!r.category || !policy.categories[r.category]) {\n  valid = false; reason = `Category \"${r.category || 'unknown'}\" is not an allowed expense category.`;\n} else if (r.amount_cents > policy.categories[r.category].maxAmountCents) {\n  const max = (policy.categories[r.category].maxAmountCents / 100).toFixed(2);\n  const amt = (r.amount_cents / 100).toFixed(2);\n  valid = false; reason = `$${amt} exceeds the ${r.category} limit of $${max}.`;\n}\nreturn [{ json: { ...j, valid, reason } }];"
      },
      "id": "node-008",
      "name": "Validate Policy",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
        440
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "id": "cond-policy",
              "leftValue": "={{ $json.valid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-009",
      "name": "Policy OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        2480,
        440
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "post",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $('Load Config').first().json.trigger.channelId }}"
        },
        "messageType": "text",
        "text": "=:warning: Receipt not reimbursed — {{ $json.reason }}",
        "otherOptions": {
          "thread_ts": {
            "replyValues": {
              "thread_ts": "={{ $('Load Config').first().json.trigger.threadTs }}"
            }
          }
        }
      },
      "id": "node-010",
      "name": "Reply: Out of Policy",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.3,
      "position": [
        2760,
        240
      ],
      "credentials": {
        "slackApi": {
          "id": "REPLACE",
          "name": "Slack account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const j = $input.first().json;\nconst roster = j.config.roster || {};\nconst entry = roster[j.trigger.userId] || null;\nconst known = !!(entry && entry.ruleId && entry.ruleId !== 'REPLACE_WITH_RULE_ID');\nreturn [{ json: { ...j, contractor: entry, contractorKnown: known } }];"
      },
      "id": "node-011",
      "name": "Resolve Contractor",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2760,
        640
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "id": "cond-known",
              "leftValue": "={{ $json.contractorKnown }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-012",
      "name": "Contractor Known?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        3040,
        640
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "post",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $('Load Config').first().json.trigger.channelId }}"
        },
        "messageType": "text",
        "text": "=:warning: No payout rule is configured for <@{{ $('Load Config').first().json.trigger.userId }}>. Add them to the roster in the *Load Config* node.",
        "otherOptions": {
          "thread_ts": {
            "replyValues": {
              "thread_ts": "={{ $('Load Config').first().json.trigger.threadTs }}"
            }
          }
        }
      },
      "id": "node-013",
      "name": "Reply: No Payout Rule",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.3,
      "position": [
        3320,
        440
      ],
      "credentials": {
        "slackApi": {
          "id": "REPLACE",
          "name": "Slack account"
        }
      }
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendAndWait",
        "select": "user",
        "user": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $('Resolve Contractor').first().json.config.slack.approverUserId }}"
        },
        "message": "=*Reimbursement approval needed*\n• Contractor: {{ $('Resolve Contractor').first().json.contractor.name }}\n• Vendor: {{ $('Resolve Contractor').first().json.receipt.vendor }}\n• Category: {{ $('Resolve Contractor').first().json.receipt.category }}\n• Amount: ${{ ($('Resolve Contractor').first().json.receipt.amount_cents / 100).toFixed(2) }}\n• Date: {{ $('Resolve Contractor').first().json.receipt.date }}",
        "approvalOptions": {
          "values": {
            "approvalType": "double",
            "buttonApprovalLabel": "Approve",
            "buttonDisapprovalLabel": "Reject"
          }
        },
        "options": {
          "limitWaitTime": {
            "values": {
              "limitType": "afterTimeInterval",
              "resumeAmount": 1,
              "resumeUnit": "days"
            }
          }
        }
      },
      "id": "node-014",
      "name": "Request Manager Approval",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.3,
      "position": [
        3320,
        840
      ],
      "credentials": {
        "slackApi": {
          "id": "REPLACE",
          "name": "Slack account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "id": "cond-approved",
              "leftValue": "={{ $json.data.approved }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-015",
      "name": "Approved?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        3600,
        840
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "post",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $('Resolve Contractor').first().json.trigger.channelId }}"
        },
        "messageType": "text",
        "text": "=:x: Reimbursement was rejected by the manager. No money moved.",
        "otherOptions": {
