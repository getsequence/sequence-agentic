    {
      "parameters": {
        "method": "GET",
        "url": "={{ $('Resolve Contractor').first().json.config.sequence.baseUrl }}/rules/{{ $('Resolve Contractor').first().json.contractor.ruleId }}/executions/{{ $('Fire Live Reimbursement').first().json.data.executionId }}",
        "authentication": "genericCredentialType",
